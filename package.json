{
  "name": "light-for-all-agent",
  "version": "0.1.0",
  "description": "Light for All Agent - 通用 AI Agent 桌面状态灯。悬浮三色灯，实时显示 Agent 工作状态。",
  "repository": {
    "type": "git",
    "url": "https://github.com/syh190819/light-for-all-agent.git"
  },
  "scripts": {
    "start": "tauri dev",
    "dev": "tauri dev",
    "icon": "node scripts/generate-icon.js",
    "dist": "tauri build --no-bundle && node scripts/copy-tauri-release.js",
    "dist:installer": "tauri build --bundles nsis",
    "simulate:idle": "powershell -NoProfile -Command \"Invoke-RestMethod -Uri http://127.0.0.1:37421/status -Method Post -ContentType application/json -Body '{\\\"mode\\\":\\\"idle\\\"}'\"",
    "simulate:working": "powershell -NoProfile -Command \"Invoke-RestMethod -Uri http://127.0.0.1:37421/status -Method Post -ContentType application/json -Body '{\\\"mode\\\":\\\"working\\\"}'\"",
    "simulate:waiting": "powershell -NoProfile -Command \"Invoke-RestMethod -Uri http://127.0.0.1:37421/status -Method Post -ContentType application/json -Body '{\\\"mode\\\":\\\"waiting\\\"}'\"",
    "simulate:error": "powershell -NoProfile -Command \"Invoke-RestMethod -Uri http://127.0.0.1:37421/status -Method Post -ContentType application/json -Body '{\\\"mode\\\":\\\"error\\\"}'\""
  },
  "keywords": ["agent", "status-light", "tauri", "desktop-widget", "workbuddy"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0"
  }
}
